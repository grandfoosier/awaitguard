# GitHub App credentials
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/awaitguard
MAX_DB_CONNECTIONS=10

# Server
HTTP_BIND=0.0.0.0:8080

# Runtime mode: api | worker | all
MODE=all

# Worker tuning
WORKER_CONCURRENCY=4
JOB_MAX_ATTEMPTS=5
JOB_LOCK_TIMEOUT_SECS=300

# Analysis limits
MAX_FILES=40
MAX_PATCH_BYTES=200000
MAX_FINDINGS=20
MAX_LLM_EXPLAINS=3

# LLM explanations (optional)
LLM_ENABLED=false
LLM_PROVIDER=openai           # openai | anthropic
LLM_MODEL=gpt-4.1-mini        # e.g. claude-haiku-4-5-20251001 for Anthropic
LLM_API_KEY=sk-...
LLM_TIMEOUT_SECS=20

# Logging
RUST_LOG=info
